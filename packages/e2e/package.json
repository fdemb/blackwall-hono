{
  "name": "@blackwall/e2e",
  "private": true,
  "scripts": {
    "test": "bun --env-file=.env.e2e run --bun playwright test",
    "test:ui": "bun --env-file=.env.e2e run --bun playwright test --ui",
    "test:debug": "bun --env-file=.env.e2e run --bun playwright test --debug",
    "report": "playwright show-report",
    "typecheck": "bun run --bun tsc --noEmit"
  },
  "dependencies": {
    "@blackwall/database": "workspace:*",
    "@blackwall/shared": "workspace:*",
    "drizzle-orm": "^1.0.0-beta.12-a5629fb"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/bun": "latest",
    "@types/node": "^22.0.0"
  }
}
